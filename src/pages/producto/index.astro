---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteConfig } from '../../services/siteConfig';

const config = await getSiteConfig();
---

<BaseLayout
  title="Detalle de producto"
  description="Consulta disponibilidad, precio y fotos actualizadas del iPhone seleccionado."
  image={config.hero.image}
  robots="noindex,follow"
>
  <section class="section" data-live-product-detail>
    <div class="container max-w-2xl text-center">
      <p class="eyebrow">Cargando producto</p>
      <h1 class="mt-3 text-4xl font-black sm:text-5xl">Un momento</h1>
      <p class="mt-5 leading-8 text-muted">Estamos consultando la información actualizada.</p>
    </div>
  </section>
</BaseLayout>
