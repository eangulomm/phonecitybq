---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSiteConfig } from '../../services/siteConfig';

const config = await getSiteConfig();
---

<BaseLayout
  title="Detalle de producto"
  description="Consulta disponibilidad, precio y fotos actualizadas del iPhone seleccionado."
  image={config.hero.image}
  robots="noindex,follow"
>
  <section class="section" data-live-product-detail>
    <div class="container grid min-h-[45vh] place-items-center">
      <div class="grid justify-items-center gap-4 rounded-3xl border border-line bg-paper px-8 py-7 text-center shadow-soft">
        <i class="fa-solid fa-spinner animate-spin text-3xl text-brand" aria-hidden="true"></i>
        <p class="text-lg font-black">Cargando...</p>
      </div>
    </div>
  </section>
</BaseLayout>
