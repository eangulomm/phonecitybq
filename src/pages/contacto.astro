---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteConfig } from '../services/siteConfig';
const config = await getSiteConfig();
const phoneLabel = config.phoneDisplay || `+${config.whatsapp}`;
---

<BaseLayout title="Contacto" description="Compra tu iPhone con Phone City BQ por WhatsApp o Instagram.">
  <section class="section">
    <div class="container grid gap-8 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Contacto</p>
        <h1 class="mt-3 text-4xl font-black sm:text-5xl">Compra tu proximo iPhone</h1>
        <div class="mt-8 grid gap-3 text-muted">
          <a class="inline-flex items-center gap-2" href={`https://wa.me/${config.whatsapp}`}>
            <i class="fa-brands fa-whatsapp text-brand" aria-hidden="true"></i>
            WhatsApp: {phoneLabel}
          </a>
          <a class="inline-flex items-center gap-2" href={config.social.instagram} target="_blank" rel="noreferrer">
            <i class="fa-brands fa-instagram text-brand" aria-hidden="true"></i>
            Instagram: @phonecity_bq
          </a>
          <a class="inline-flex items-center gap-2" href={config.social.tiktok} target="_blank" rel="noreferrer">
            <i class="fa-brands fa-tiktok text-brand" aria-hidden="true"></i>
            TikTok: @phonecitybq
          </a>
          {config.email && (
            <a class="inline-flex items-center gap-2" href={`mailto:${config.email}`}>
              <i class="fa-solid fa-envelope text-brand" aria-hidden="true"></i>
              Correo: {config.email}
            </a>
          )}
          <span class="inline-flex items-center gap-2"><i class="fa-solid fa-location-dot text-brand" aria-hidden="true"></i>Direccion: {config.address}</span>
        </div>
      </div>
      <form class="surface grid gap-4 rounded-[var(--radius-lg)] p-6">
        <label class="grid gap-2 font-bold">Nombre<input class="rounded-2xl border border-line bg-paper px-4 py-3 font-normal outline-none" /></label>
        <label class="grid gap-2 font-bold">Correo<input type="email" class="rounded-2xl border border-line bg-paper px-4 py-3 font-normal outline-none" /></label>
        <label class="grid gap-2 font-bold">Que iPhone buscas?<textarea rows="5" class="rounded-2xl border border-line bg-paper px-4 py-3 font-normal outline-none" placeholder="Ej: iPhone 13 Pro 256GB seminuevo"></textarea></label>
        <a class="btn-primary justify-self-start" href={`https://wa.me/${config.whatsapp}`} target="_blank" rel="noreferrer">
          <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
          Abrir WhatsApp
        </a>
      </form>
    </div>
  </section>
</BaseLayout>
