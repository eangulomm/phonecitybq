---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import Benefits from '../components/home/Benefits.astro';
import ProductSection from '../components/product/ProductSection.astro';
import ContentSections from '../components/home/ContentSections.astro';
import { getSiteConfig } from '../services/siteConfig';
import { getProducts } from '../services/products';
import { isIphoneProduct } from '../utils/productFilters';

const config = await getSiteConfig();
const products = await getProducts();
const iphoneProducts = products.filter(isIphoneProduct);
const newest = iphoneProducts.filter((product) => product.isNew || product.condition?.toLowerCase() === 'nuevo');
const preowned = iphoneProducts.filter((product) => product.condition?.toLowerCase() !== 'nuevo');
---

<BaseLayout title="iPhone nuevos y seminuevos" description={config.hero.subtitle}>
  <Hero config={config} />
  <Benefits benefits={config.benefits} />
  <ProductSection id="catalogo" eyebrow="Catalogo" title="iPhone disponibles" products={iphoneProducts} whatsapp={config.whatsapp} surface />
  <ProductSection id="nuevos" eyebrow="Nuevos" title="iPhone nuevos" products={newest} whatsapp={config.whatsapp} />
  <ProductSection id="seminuevos" eyebrow="Seminuevos" title="iPhone seminuevos revisados" products={preowned} whatsapp={config.whatsapp} surface />
  <ContentSections config={config} />
</BaseLayout>
