---
import ProductCarousel from './ProductCarousel.astro';
import { sitePath } from '../../utils/format';

const { eyebrow, title, products, surface = false, whatsapp, id, viewAllHref = '/productos' } = Astro.props;
const carouselId = `${id || title.toLowerCase().replace(/\s+/g, '-')}-carousel`;
---

<section id={id} class={`section ${surface ? 'bg-surface' : ''}`}>
  <div class="container">
    <div class="mb-8 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h2 class="mt-3 text-3xl font-black sm:text-4xl">{title}</h2>
      </div>
      <a class="btn-secondary self-start sm:self-auto" href={sitePath(viewAllHref)}>
        Ver catalogo
      </a>
    </div>
    <ProductCarousel products={products} whatsapp={whatsapp} carouselId={carouselId} />
  </div>
</section>
