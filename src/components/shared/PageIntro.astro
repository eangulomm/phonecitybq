---
import { sitePath } from '../../utils/format';

const { eyebrow, title, description, actions = [] } = Astro.props;
---

<div class="mb-8 grid gap-4 lg:grid-cols-[1fr_auto] lg:items-end">
  <div>
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h1 class="mt-3 text-4xl font-black leading-tight sm:text-5xl">{title}</h1>
    {description && <p class="mt-4 max-w-2xl leading-7 text-muted">{description}</p>}
  </div>
  {
    actions.length > 0 && (
      <div class="flex flex-wrap gap-3">
        {actions.map((action) => (
          <a class={action.variant === 'primary' ? 'btn-primary' : 'btn-secondary'} href={sitePath(action.href)}>
            {action.label}
          </a>
        ))}
      </div>
    )
  }
</div>
