---
import { sitePath } from '../../utils/format';

const { categories } = Astro.props;
---

<section class="section">
  <div class="container">
    <div class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end">
      <div>
        <p class="eyebrow">Explora por necesidad</p>
        <h2 class="mt-3 text-3xl font-black sm:text-4xl">Categorias destacadas</h2>
      </div>
      <a href={sitePath('/productos')} class="btn-secondary">Ver todo</a>
    </div>
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {categories.map((category) => (
        <a href={sitePath(`/categoria/${category.slug}`)} class="group relative min-h-72 overflow-hidden rounded-[var(--radius-lg)] bg-ink text-white shadow-soft">
          <img class="absolute inset-0 h-full w-full object-cover opacity-65 transition duration-300 group-hover:scale-105" src={category.image} alt={category.name} loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/20 to-transparent"></div>
          <div class="relative flex h-full min-h-72 flex-col justify-end p-6">
            <h3 class="text-2xl font-black">{category.name}</h3>
            <p class="mt-2 text-sm leading-6 text-white/78">{category.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
