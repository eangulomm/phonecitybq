---
const { brands } = Astro.props;
---

<section class="section bg-surface">
  <div class="container text-center">
    <p class="eyebrow">Marcas aliadas</p>
    <h2 class="mt-3 text-3xl font-black">Catalogo multimarcas</h2>
    <div class="mt-8 grid grid-cols-2 gap-px overflow-hidden rounded-[var(--radius-lg)] border border-line bg-line sm:grid-cols-3 lg:grid-cols-6">
      {brands.map((brand) => (
        <div class="grid min-h-24 place-items-center bg-surface px-4 text-lg font-black text-muted transition hover:text-ink">{brand}</div>
      ))}
    </div>
  </div>
</section>
