---
const { config } = Astro.props;
---

<section class="section">
  <div class="container grid gap-5 lg:grid-cols-[1.25fr_0.75fr]">
    <div class="rounded-[var(--radius-lg)] bg-ink p-8 text-paper sm:p-10">
      <p class="eyebrow text-accent">Pagos y entrega</p>
      <h2 class="mt-3 max-w-2xl text-3xl font-black sm:text-4xl">Compra tu iPhone con atencion clara desde el primer mensaje</h2>
      <div class="mt-8 flex flex-wrap gap-3">
        {config.paymentMethods.map((method) => <span class="rounded-full border border-white/15 px-4 py-2 text-sm font-bold text-paper/80">{method}</span>)}
      </div>
    </div>
    <div class="surface rounded-[var(--radius-lg)] p-8">
      <p class="eyebrow">Asesoria activa</p>
      <h2 class="mt-3 text-3xl font-black">{config.banners[0].title}</h2>
      <p class="mt-4 leading-7 text-muted">{config.banners[0].text}</p>
      <a href={config.banners[0].href} class="btn-primary mt-6">
        <i class="fa-solid fa-mobile-screen-button" aria-hidden="true"></i>
        Ver iPhone
      </a>
    </div>
  </div>
</section>

<section class="section bg-surface">
  <div class="container grid gap-10 lg:grid-cols-[0.7fr_1.3fr]">
    <div>
      <p class="eyebrow">Clientes</p>
      <h2 class="mt-3 text-3xl font-black">Asesoria antes de comprar</h2>
      <p class="mt-4 leading-7 text-muted">Phone City BQ esta pensado para que elijas tu iPhone con informacion clara de modelo, precio y condicion.</p>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {config.testimonials.map((item) => (
        <article class="rounded-[var(--radius-md)] border border-line bg-paper p-6">
          <p class="text-sm leading-7 text-muted">"{item.text}"</p>
          <h3 class="mt-5 font-black">{item.name}</h3>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container grid gap-8 lg:grid-cols-2">
    <div>
      <p class="eyebrow">FAQ</p>
      <h2 class="mt-3 text-3xl font-black">Preguntas frecuentes</h2>
    </div>
    <div class="grid gap-3">
      {config.faq.map((item) => (
        <details class="surface rounded-2xl p-5">
          <summary class="cursor-pointer font-black">{item.q}</summary>
          <p class="mt-3 leading-7 text-muted">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="pb-16">
  <div class="container rounded-[var(--radius-lg)] bg-brand p-8 text-white sm:p-10">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div>
        <h2 class="text-3xl font-black">Quieres comprar un iPhone?</h2>
        <p class="mt-3 text-white/78">Escríbenos por WhatsApp y te ayudamos a confirmar modelo, capacidad, condicion y disponibilidad.</p>
      </div>
      <a class="inline-flex items-center gap-2 justify-self-start rounded-full bg-white px-6 py-3 font-black text-slate-950 lg:justify-self-end" href={`https://wa.me/${config.whatsapp}`} target="_blank" rel="noreferrer">
        <i class="fa-brands fa-whatsapp" aria-hidden="true"></i>
        Abrir WhatsApp
      </a>
    </div>
  </div>
</section>
