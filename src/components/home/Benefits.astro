---
const { benefits } = Astro.props;
---

<section class="border-y border-line bg-paper py-8">
  <div class="container grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {benefits.map((benefit, index) => (
      <article class="flex gap-4 rounded-2xl bg-surface p-5">
        <span class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-brand/10 font-black text-brand">{index + 1}</span>
        <div>
          <h2 class="text-sm font-black">{benefit.title}</h2>
          <p class="mt-1 text-sm leading-6 text-muted">{benefit.text}</p>
        </div>
      </article>
    ))}
  </div>
</section>
