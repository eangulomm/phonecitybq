---
import { sitePath } from '../../utils/format';

const { config } = Astro.props;
const whatsappUrl = `https://wa.me/${config.whatsapp}`;
const heroSlides = [
  {
    image: '/images/phonecity-hero-apple.png',
    imageAlt: 'Equipos Apple destacados de Phone City BQ',
    eyebrow: 'Phone City BQ',
    title: 'Lo mejor de Apple',
    text: 'iPhone, iPad y MacBook con atención directa.',
    actions: [
      {
        label: 'Escríbenos por WhatsApp',
        href: whatsappUrl,
        icon: 'fa-brands fa-whatsapp',
        variant: 'primary',
      },
    ],
  },
  {
    image: '/images/phonecity-hero-social.png',
    imageAlt: 'Tecnología Apple y accesorios Phone City BQ',
    eyebrow: 'Comunidad',
    title: 'Tecnología que te mueve',
    text: 'Síguenos para ver novedades, disponibilidad y promociones.',
    actions: [
      {
        label: 'Instagram',
        href: config.social?.instagram || '#',
        icon: 'fa-brands fa-instagram',
        variant: 'primary',
      },
      {
        label: 'TikTok',
        href: config.social?.tiktok || '#',
        icon: 'fa-brands fa-tiktok',
        variant: 'secondary',
      },
    ],
  },
];
---

<section class="hero-carousel overflow-hidden bg-surface" data-hero-carousel aria-roledescription="carousel" aria-label="Promociones principales">
  <div class="container py-6 sm:py-8">
    <div class="relative overflow-hidden rounded-[2rem] border border-line bg-brand shadow-lift">
      <div class="hero-track flex transition-transform duration-700 ease-out" data-hero-track>
        {heroSlides.map((slide, index) => (
          <article class="hero-slide relative min-w-full overflow-hidden" aria-hidden={index === 0 ? 'false' : 'true'}>
            <img
              class="absolute inset-0 h-full w-full object-cover"
              src={sitePath(slide.image)}
              alt={slide.imageAlt}
              fetchpriority={index === 0 ? 'high' : undefined}
              loading={index === 0 ? undefined : 'lazy'}
            />
            <div class="absolute inset-0 bg-gradient-to-r from-black/40 via-black/10 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-4 sm:p-6 lg:p-8">
              <div class="max-w-xl rounded-3xl border border-white/20 bg-black/28 p-4 text-white shadow-lift backdrop-blur-md sm:p-5">
                <p class="text-xs font-black uppercase tracking-wide text-white/80">{slide.eyebrow}</p>
                <h1 class="mt-2 text-3xl font-black leading-tight sm:text-5xl">{slide.title}</h1>
                <p class="mt-2 max-w-md text-sm leading-6 text-white/85 sm:text-base">{slide.text}</p>
                <div class="mt-4 flex flex-col gap-2 sm:flex-row">
                  {slide.actions.map((action) => (
                    <a
                      href={action.href}
                      class={action.variant === 'primary' ? 'btn-primary bg-white text-brand hover:bg-white/90' : 'btn-secondary border-white/35 bg-white/10 text-white hover:bg-white/20'}
                      target={action.href.startsWith('http') ? '_blank' : undefined}
                      rel={action.href.startsWith('http') ? 'noreferrer' : undefined}
                    >
                      <i class={action.icon} aria-hidden="true"></i>
                      {action.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <button class="absolute left-4 top-1/2 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-white/25 bg-black/25 text-white shadow-soft backdrop-blur transition hover:bg-black/40 sm:grid" type="button" data-hero-prev aria-label="Slide anterior">
        <i class="fa-solid fa-chevron-left" aria-hidden="true"></i>
      </button>
      <button class="absolute right-4 top-1/2 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-white/25 bg-black/25 text-white shadow-soft backdrop-blur transition hover:bg-black/40 sm:grid" type="button" data-hero-next aria-label="Siguiente slide">
        <i class="fa-solid fa-chevron-right" aria-hidden="true"></i>
      </button>

      <div class="absolute bottom-4 right-4 flex items-center gap-2 rounded-full border border-white/20 bg-black/25 p-2 shadow-soft backdrop-blur" data-hero-dots>
        {heroSlides.map((_, index) => (
            <button class={`h-2.5 rounded-full transition-all ${index === 0 ? 'w-8 bg-white' : 'w-2.5 bg-white/45'}`} type="button" data-hero-dot={index} aria-label={`Ir al slide ${index + 1}`} aria-current={index === 0 ? 'true' : 'false'}></button>
        ))}
      </div>
    </div>
  </div>
</section>
